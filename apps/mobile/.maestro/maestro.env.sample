# Copy this file to .maestro/maestro.env.local and adjust values per worktree.

TASK_ID="${TASK_ID:-ad-hoc}"

# The iOS dev-client build cache is SHARED across every worktree: a single
# host-local root, owned by apps/mobile/scripts/maestro-env.sh (defaults to
# $HOME/.cache/boga/maestro/ios-dev-client). A fresh worktree reuses an
# already-built client instead of rebuilding from scratch. The .app path is
# always derived from this root, so the build-write and cache-lookup paths can
# never diverge.
#
# Deliberately leave MAESTRO_IOS_SHARED_BUILD_ROOT / MAESTRO_IOS_DEV_CLIENT_APP_PATH
# UNSET here. This sample is sourced BEFORE maestro.env.local, so setting them
# would shadow both the per-worktree value and the canonical default — the
# historical cause of build-path vs lookup-path drift. To relocate the whole
# cache, export MAESTRO_IOS_SHARED_BUILD_ROOT in your environment, then rebuild
# with `./scripts/maestro-ios-dev-client-build.sh --force` after any NATIVE
# dependency or app.config.ts native-field change.

# Runtime scripts fail fast until apps/mobile/.maestro/maestro.env.local exists.
# Copy this file there, then set a dedicated simulator target and Metro port.
# Prefer IOS_SIM_UDID when multiple worktrees or humans/agents share one Mac.
IOS_SIM_DEVICE="${IOS_SIM_DEVICE:-}"
IOS_SIM_UDID="${IOS_SIM_UDID:-}"
# Default ON. This sample is sourced BEFORE maestro.env.local, so a 0 here would
# pin the variable and silently override the worktree's intended 1. Keep this 1
# so the smoke gate auto-creates a missing slot-named simulator. Set to 0 only
# if you want device lookups to fail fast instead of self-healing.
IOS_SIM_AUTO_CREATE="${IOS_SIM_AUTO_CREATE:-1}"

# Required: set a unique EXPO_DEV_SERVER_PORT per worktree on a shared host.
EXPO_DEV_SERVER_PORT="${EXPO_DEV_SERVER_PORT:-}"
EXPO_START_WAIT_SECONDS="${EXPO_START_WAIT_SECONDS:-30}"
MAESTRO_KEEP_SIMULATOR_BOOTED="${MAESTRO_KEEP_SIMULATOR_BOOTED:-0}"
