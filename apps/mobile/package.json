{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:ios:dev-client": "./scripts/ios-dev-client-start.sh",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:ui-guardrails": "node ./scripts/check-ui-guardrails.js",
    "router:types": "node ./scripts/generate-router-types.js",
    "typecheck": "npm run router:types && tsc --noEmit",
    "test": "jest",
    "test:handles": "jest --detectOpenHandles --silent",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts && tsx scripts/bundle-migrations.ts",
    "db:generate:canary": "npm run db:generate",
    "check:sync-drift": "tsx scripts/check-sync-schema-drift.ts",
    "test:sync:reinstall-parity": "./scripts/test-sync-reinstall-restore-parity.sh",
    "test:e2e:ios:smoke": "./scripts/maestro-ios-smoke.sh",
    "test:e2e:ios:data-smoke": "./scripts/maestro-ios-data-smoke.sh",
    "test:e2e:ios:gates": "./scripts/maestro-ios-gates.sh",
    "test:e2e:ios:auth-profile": "./scripts/maestro-ios-auth-profile.sh"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.98.0",
    "drizzle-orm": "^0.44.6",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "29.5.14",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.1.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "pg": "^8.21.0",
    "react-test-renderer": "^19.1.0",
    "tsx": "^4.22.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
